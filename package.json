    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.6.5",
    "@rspack/core": "^2.1.3",
    "@rstest/adapter-rslib": "^0.11.0",
    "@rstest/core": "^0.11.0",
    "@types/node": "^24.13.2",
    "prettier": "^3.9.4",
    "terser-webpack-plugin": "^5.6.1",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.10.0"
}
