{
  "name": "rspack-merge",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rstackjs/rspack-merge.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "bump": "npx bumpp",
    "dev": "rslib -w",
    "format": "prettier --write .",
    "lint": "rslint",
    "lint:write": "rslint --fix",
    "prettier:ci": "prettier --check .",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@rslib/core": "^0.21.3",
    "@rslint/core": "^0.4.2",
    "@rspack/core": "^2.0.1",
    "@rstest/adapter-rslib": "^0.2.2",
    "@rstest/core": "^0.9.8",
    "@types/node": "^20.19.39",
    "prettier": "^3.8.2",
    "terser-webpack-plugin": "^5.5.0",
    "typescript": "^6.0.3"
  },
  "private": true
}
