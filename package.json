{
  "name": "rspack-merge",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rstackjs/rspack-merge.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
